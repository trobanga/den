# Rust flavor: the shared base (den:base) plus only the Rust toolchain.
# Everything common — apt, bun+pi, node20+bd, user, ssh, tmux, entrypoint — lives
# in the base image (Dockerfile). run.sh / Justfile build den:base first.
FROM den:base

# Toolchain installs land in /usr/local, so do them as root.
USER root

# Rust-only native-build deps (folded into the shared apt block before den-7yk).
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain (rustup) at image scope so any UID can use it.
ARG RUST_VERSION=stable
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --no-modify-path --default-toolchain ${RUST_VERSION} --profile minimal \
  && chmod -R a+w "$RUSTUP_HOME" "$CARGO_HOME" \
  && rustc --version && cargo --version

# Install sccache via cargo. Done as root so the binary lands in shared CARGO_HOME.
RUN cargo install sccache --locked \
  && sccache --version

# sccache cache dir (base creates .claude, not .cache); host mounts it read-write.
RUN mkdir -p /home/node/.cache/sccache && chown -R node:node /home/node/.cache

USER node

# Wire sccache as the rustc wrapper and point it at the host-mounted cache dir.
ENV RUSTC_WRAPPER=sccache \
    SCCACHE_DIR=/home/node/.cache/sccache

# Interactive SSH zsh login: base ran the zsh prompt setup, append cargo PATH + env.
RUN printf '%s\n' \
      'export PATH="$PATH:/usr/local/cargo/bin"' \
      'export RUSTC_WRAPPER=sccache' \
      'export SCCACHE_DIR=/home/node/.cache/sccache' \
      >> /home/node/.zshrc

USER node
# ENTRYPOINT / EXPOSE / WORKDIR inherited from den:base.
